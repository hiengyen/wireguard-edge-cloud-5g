# ==============================================================
# Shared environment example for Terraform, monitoring, and edge runtime
# Load with:
#   cp .env.example .env
#   set -a && . ./.env && set +a
# ==============================================================

# ==============================================================
# Terraform / Cloud
# These variables are consumed by Terraform as TF_VAR_* inputs.
# ==============================================================

# AWS region for the EC2 deployment
TF_VAR_aws_region=ap-southeast-1

# EC2 instance size for the cloud gateway
TF_VAR_instance_type=t3.medium

# WireGuard API registration token.
# Must be at least 32 characters in production.
TF_VAR_wg_api_token='REPLACE_WITH_A_STRONG_RANDOM_TOKEN'

# CIDRs allowed to SSH to the EC2 instance.
# Keep this restricted to your public IP or office range.
TF_VAR_admin_ssh_cidr='["203.0.113.10/32"]'

# Whether to expose the Registration API through the security group.
# false = manual peer registration only
# true  = enable public TLS ingress for the Registration API
TF_VAR_enable_registration_api=false

# CIDR allowed to reach the Registration API TLS endpoint when enabled.
# Restrict this to the known edge egress IP or another trusted source.
TF_VAR_wg_api_cidr=198.51.100.20/32

# Public TLS port for the Registration API reverse proxy
TF_VAR_registration_api_tls_port=443

# Optional public hostname for the Registration API certificate bootstrap.
# Leave empty to use the EC2 Elastic IP automatically.
TF_VAR_registration_api_domain=''

# WireGuard overlay network settings
TF_VAR_wireguard_port=51820
TF_VAR_wireguard_network=10.8.0.0/24

# Sample edge peer address used in examples and initial monitoring targets.
# Each real edge node must use its own unique /32.
TF_VAR_wireguard_client_cidr=10.8.0.2/32

# ==============================================================
# Monitoring
# These values are used by cloud/monitoring/docker-compose.yml
# ==============================================================

# Grafana admin password
GRAFANA_ADMIN_PASSWORD='CHANGE_ME_BEFORE_DEPLOYMENT'

# Default bind address for Grafana and Prometheus on the cloud node.
# 127.0.0.1 = local only, use SSH tunnel for access
# 10.8.0.1  = reachable through the WireGuard overlay
MONITORING_BIND_ADDRESS=127.0.0.1

# When true, hardening.sh opens Grafana, Prometheus, and Node Exporter
# over the WireGuard interface/network on the host firewall.
ALLOW_MONITORING_OVER_WIREGUARD=false

# Monitoring service ports
GRAFANA_PORT=3000
PROMETHEUS_PORT=9090

# ==============================================================
# Edge runtime
# These values are used by the edge WWAN and WireGuard client scripts.
# ==============================================================

# Keep this aligned with TF_VAR_wireguard_port unless you intentionally change it
WIREGUARD_PORT=51820

# Overlay-only routing default for the edge client
WIREGUARD_ALLOWED_IPS=10.8.0.0/24

# Registration API scheme used by setup-wg-client.sh
WIREGUARD_API_SCHEME=https

# APN used by the WWAN setup on the edge node
WWAN_APN=internet

# SSH port opened by hardening.sh on the edge host
SSH_ADMIN_PORT=22

# Extra inbound TCP ports opened by hardening.sh on edge hosts using UFW
# Default repository policy opens 443 and 5201, but not 8006 or 64203
EDGE_EXTRA_TCP_PORTS='443 5201'
