[Unit]
Description=WWAN QMI Auto-Connect
Wants=network-online.target
After=network.target network-online.target multi-user.target
StartLimitIntervalSec=120
StartLimitBurst=5

[Service]
Type=simple
EnvironmentFile=-/etc/default/wwan
ExecStart=/usr/local/bin/quectel-CM -s ${WWAN_APN}
ExecStop=/usr/local/bin/wwan-stop.sh
Restart=always
RestartSec=10
TimeoutStartSec=180

[Install]
WantedBy=multi-user.target
