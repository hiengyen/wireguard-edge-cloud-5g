aws_region   = "ap-southeast-1"
project_name = "wireguard-vpn"

vpc_id    = "vpc-xxxxxxxxxxxxxxxxx"
subnet_id = "subnet-xxxxxxxxxxxxxxxxx"

instance_type = "t3.medium"
key_name      = "your-key-pair-name"

wireguard_port    = 51820
wireguard_network = "10.8.0.0/24"
wireguard_client_cidr = "10.8.0.2/32"
root_volume_size  = 20

# CheckIP: https://checkip.amazonaws.com
admin_ssh_cidr = ["<YOUR_PUBLIC_IP>/32"]


common_tags = {
  Project     = "WireGuard-VPN"
  ManagedBy   = "Terraform"
  Environment = "production"
}

# Monitoring stack examples
#   export TF_VAR_grafana_admin_password="change-this-before-exposing-grafana"
